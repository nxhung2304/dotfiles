{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "terminal-notifier -title \"✅ $(basename \"$PWD\")\" -message 'CC - Task done' -sound default"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "terminal-notifier -title \"🔔 $(basename \"$PWD\")\" -message 'CC - Need user input' -sound Basso"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash /Users/rightsvn-hung/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "lua-lsp@claude-plugins-official": true,
    "ruby-lsp@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true
  },
  "permissions": {
    "allow": [
      "Read(~/.claude/code-rules/**)"
    ]
  },
  "effortLevel": "medium",
  "autoMemoryEnabled": false,
  "hasCompletedOnboarding": true
}
