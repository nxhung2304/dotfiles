#!/usr/bin/env bash
# Open URL in browser, focusing existing tab if already open.
# Supports: Arc, Google Chrome, Brave Browser, Safari.
URL="$1"
[ -z "$URL" ] && exit 1

focus_tab() {
  local app="$1"
  osascript << EOF 2>/dev/null
tell application "$app"
  repeat with w in windows
    set tabIndex to 0
    repeat with t in tabs of w
      set tabIndex to tabIndex + 1
      if URL of t = "$URL" or URL of t starts with "$URL/" then
        set active tab index of w to tabIndex
        set index of w to 1
        activate
        return "found"
      end if
    end repeat
  end repeat
  return "not_found"
end tell
EOF
}

for app in "Arc" "Google Chrome" "Brave Browser" "Safari"; do
  if pgrep -ix "$app" > /dev/null 2>&1; then
    result=$(focus_tab "$app")
    [ "$result" = "found" ] && exit 0
  fi
done

open "$URL"
